# ============================================================
# Pudding Resume Backend — 配置文件模板
# 使用方法: 复制为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# 后端服务端口
SERVER_PORT=8080

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=pudding_resume
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# JWT 配置
# 生产环境请务必使用强随机字符串（推荐: openssl rand -hex 32）
JWT_SECRET=CHANGE_ME
# Access Token 过期时间（默认 1 小时）
JWT_EXPIRATION=1h
# Refresh Token 过期时间（默认 168 小时 = 7 天）
JWT_REFRESH_EXPIRATION=168h

# 上传文件目录
UPLOAD_DIR=./uploads

# Chromium/Chrome 浏览器路径（用于 PDF/PNG 导出）
# 留空则自动从系统 PATH 查找
# Windows:  C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:    /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:    /usr/bin/chromium-browser
CHROMIUM_PATH=

# 字体文件目录（用于 PDF/PNG 导出时嵌入中文字体）
FONTS_DIR=./fonts
# 字体 CDN 基础地址（导出时如果本地缺少字体文件，自动从 CDN 下载缓存）
# 和前端 .env.production 中 VITE_FONT_BASE_URL 配置相同的 jsDelivr 地址
FONT_CDN_BASE_URL=https://cdn.jsdelivr.net/gh/mikulc/pudding-resume-fonts@v1.1.0

# CORS 允许的前端来源（逗号分隔）
# 开发环境默认: http://localhost:5173,http://127.0.0.1:5173
# 生产环境改为实际域名: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
