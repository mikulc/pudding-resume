# Frontend production configuration example
# Copy to frontend/.env.production and adjust values for deployment.

# API base URL. Leave empty for same-origin deployment behind Nginx.
# Use a full URL for split frontend/backend deployments.
VITE_API_BASE=

# Base URL for full font files. Leave empty to use `${VITE_API_BASE}/api/font-files`.
# Example CDN value: https://cdn.example.com/pudding-resume/fonts
VITE_FONT_BASE_URL=https://cdn.jsdelivr.net/gh/mikulc/pudding-resume-fonts@v1.1.0

# Font files are served directly by the backend as full woff2 files.
# No subsetting is needed — the browser caches the files after first download.
